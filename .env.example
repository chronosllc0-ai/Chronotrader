# =============================================================================
# ChronoTrader Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# ── Blockchain ──────────────────────────────────────────────────────────────
# Private key for the agent wallet (DO NOT commit real keys)
AGENT_PRIVATE_KEY=0x...
# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
LOCAL_RPC_URL=http://localhost:8545
# Active network (local | base_sepolia | base)
NETWORK=local

# ── Deployed Contract Addresses ─────────────────────────────────────────────
# These will be populated after deployment
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=
RISK_ROUTER_ADDRESS=
STRATEGY_VAULT_ADDRESS=

# ── Hackathon Sandbox ───────────────────────────────────────────────────────
# Provided by hackathon organizers
SANDBOX_VAULT_ADDRESS=
SANDBOX_RISK_ROUTER_ADDRESS=

# ── Chainlink ───────────────────────────────────────────────────────────────
# ETH/USD, BTC/USD price feed addresses on Base Sepolia
CHAINLINK_ETH_USD_FEED=
CHAINLINK_BTC_USD_FEED=

# ── IPFS ────────────────────────────────────────────────────────────────────
IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_UPLOAD_API=  # Pinata, Infura, or web3.storage

# ── Agent Configuration ─────────────────────────────────────────────────────
AGENT_ID=1
AGENT_NAME=ChronoTrader
AGENT_DESCRIPTION=Autonomous AI trading agent with ERC-8004 trust
MAX_POSITION_SIZE_USD=1000
MAX_DAILY_LOSS_PCT=5
MAX_DRAWDOWN_PCT=15
DEFAULT_STRATEGY=momentum
